{
  "expo": {
    "name": "Mongez",
    "slug": "mongez-app",
    "version": "1.0.0",
    "scheme": "mongezapp",
    "platforms": ["ios", "android"],
    "android": {
      "softwareKeyboardLayoutMode": "resize"
    },
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2E7D32"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": { "newArchEnabled": true },
          "ios": { "newArchEnabled": true }
        }
      ],
      "expo-splash-screen"
    ]
  }
}
